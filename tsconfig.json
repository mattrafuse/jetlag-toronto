{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx"
  },
  "include": [
    "main.ts",
    "vite-env.d.ts",
    "**/*.d.ts",
    "layers/**/*.ts",
    "questions/**/*.ts",
    "questions/**/*.tsx",
    "types.ts"
  ]
}
