{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "paths": {
      "settings/*": ["./settings/*"],
      "layers/*": ["./layers/*"],
      "questions": ["./questions/index.ts"],
      "questions/*": ["./questions/*"],
      "store-hook": ["./store-hook.ts"],
      "constants": ["./constants.ts"]
    }
  },
  "include": ["main.ts", "vite-env.d.ts", "**/*.d.ts", "**/*.tsx?", "types.ts"],
  "exclude": ["questions/**/*.test.ts"]
}
