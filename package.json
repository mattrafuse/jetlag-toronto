{
  "name": "jetlag",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently --kill-others -p \"[{name}]\" -n UI,API \"pnpm dev:ui\" \"pnpm dev:server\"",
    "dev:ui": "vite",
    "dev:server": "PORT=3001 node --experimental-strip-types --watch server/index.ts",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "server": "node --experimental-strip-types server/index.ts"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^9.2.0",
    "@mui/material": "^9.2.0",
    "@turf/turf": "^7.3.5",
    "esri-leaflet": "^3.0.19",
    "express": "^5.2.1",
    "geojson": "^0.5.0",
    "leaflet": "^1.9.4",
    "leaflet-editable": "^1.3.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "workbox-routing": "^7.4.1",
    "workbox-strategies": "^7.4.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/esri-leaflet": "^3.0.4",
    "@types/express": "^5.0.6",
    "@types/geojson": "^7946.0.16",
    "@types/leaflet": "^1.9.17",
    "@types/leaflet-editable": "^1.2.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.1",
    "@vitest/coverage-v8": "^4.1.10",
    "concurrently": "^10.0.3",
    "jsdom": "^29.1.1",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "oxlint-tsgolint": "^0.24.0",
    "supertest": "^7.2.2",
    "typescript": "^7.0.2",
    "vite": "^6.3.5",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.10"
  }
}
